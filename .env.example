# Expo app — copy to `.env` and adjust.
# Use a development build (npm run android), NOT Expo Go.
#
# Physical phone on Wi‑Fi: PC LAN IP (ipconfig → IPv4), NOT 127.0.0.1
EXPO_PUBLIC_API_URL=http://192.168.1.9:3000/api
#
# USB + adb reverse tcp:3000 tcp:3000 only:
# EXPO_PUBLIC_API_USE_ENV_ONLY=1
# EXPO_PUBLIC_API_URL=http://127.0.0.1:3000/api
# Android emulator + API on another host’s LAN IP:
# EXPO_PUBLIC_API_SKIP_EMULATOR_HOST=1

# Google Sign-In
#
# --- Expo Go (managed / `npx expo start` + Expo Go app) ---
# Google rejects redirect_uri=exp://… You must use a Web application OAuth client and allow
# the Expo AuthSession proxy redirect on that client (Credentials → your Web client → Authorized redirect URIs):
#   https://auth.expo.io/@anonymous/whispr
# If you use `expo login`, set EXPO_PUBLIC_EXPO_AUTH_REDIRECT_PROJECT=@yourname/whispr and add that URL instead.
# EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID is ignored in Expo Go; the Web client ID below is what matters.
#
# --- Development / release build (expo run / EAS) on device ---
# Use EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID (Android OAuth type) or EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID (iOS type)
# with package name + SHA-1 / Bundle ID as in Google Cloud Console.

# Web application OAuth client ID (type "Web" in Google Cloud). The app prefers this variable
# over EXPO_PUBLIC_GOOGLE_CLIENT_ID so you can keep Android/Web IDs separate.
# Add redirect URI on this Web client: https://auth.expo.io/@anonymous/whispr (see above).
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=

# Optional alias; if unset, EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID is still enough.
EXPO_PUBLIC_GOOGLE_CLIENT_ID=

# Optional: override proxy path if not @anonymous/<slug> (e.g. after `expo login`).
# EXPO_PUBLIC_EXPO_AUTH_REDIRECT_PROJECT=@yourname/whispr

# Android OAuth client (type "Android") — for dev/release APK, not Expo Go.
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=

# iOS OAuth client (type "iOS") — for dev/release iOS build.
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=

# Never put OAuth client secrets in the Expo app or EXPO_PUBLIC_* — they are public in the bundle.
# Use secrets only on your backend (e.g. backend/.env) for server-side flows.
