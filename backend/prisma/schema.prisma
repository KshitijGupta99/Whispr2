generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum Status {
  PROCESSING
  READY
  FAILED
}

model User {
  id         String      @id
  email      String      @unique
  name       String
  avatar     String?
  audiobooks Audiobook[]
  createdAt  DateTime    @default(now())
}

model Audiobook {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title         String
  voiceId       String
  status        Status    @default(PROCESSING)
  duration      Int?
  progress      Int       @default(5)
  currentStep   String    @default("Starting...")
  chaptersReady Int       @default(0)
  totalChapters Int       @default(0)
  errorMessage  String?
  manuscript    String
  chapters      Chapter[]
  createdAt     DateTime  @default(now())
}

model Chapter {
  id           String    @id @default(cuid())
  audiobookId  String
  audiobook    Audiobook @relation(fields: [audiobookId], references: [id], onDelete: Cascade)
  index        Int
  title        String
  audioUrl     String
  duration     Int
  waveformData String    @default("[]")
}
