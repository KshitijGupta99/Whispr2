PORT=3000
HOST=0.0.0.0
JWT_SECRET=change-me-in-production

# SQLite database (created automatically on first migrate)
DATABASE_URL="file:./prisma/dev.db"

# OpenAI — Whisper, GPT chapter split, and TTS (recommended)
OPENAI_API_KEY=
DEFAULT_TTS_PROVIDER=openai
# OPENAI_CHAT_MODEL=gpt-4o-mini
# OPENAI_TTS_MODEL=tts-1
# OPENAI_TRANSCRIBE_MODEL=whisper-1

# ElevenLabs (optional; set DEFAULT_TTS_PROVIDER=elevenlabs)
ELEVENLABS_API_KEY=

# Google Sign-In — use the same Web client ID as EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID
GOOGLE_WEB_CLIENT_ID=
# Optional additional audiences
# GOOGLE_ANDROID_CLIENT_ID=
# GOOGLE_IOS_CLIENT_ID=

# Local dev only: accept Google tokens without verification (not for production)
# DEV_AUTH_BYPASS=1
